# Astro hashed assets — filenames change on every build, so they're immutable.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Screenshots — not content-addressed; use a short cache so updates propagate.
/screenshots/*
  Cache-Control: public, max-age=86400

# Fonts served from our origin (if any are ever self-hosted).
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
