---
import BaseLayout from "../layouts/BaseLayout.astro";
import TerminalAnimation from "../components/TerminalAnimation";

const heroChips = [
  "Workflow fingerprints",
  "Quality attribution",
  "Cost per successful outcome",
  "Exemplar sessions",
];

const proofSignals = [
  {
    label: "Fingerprint workflows",
    detail: "Archetypes and session fingerprints tied to what happened next.",
  },
  {
    label: "Prove quality and cost",
    detail: "See which workflows lead to better PR outcomes per dollar.",
  },
  {
    label: "Standardize what works",
    detail: "Turn bright spots into exemplars, playbooks, and reusable assets.",
  },
  {
    label: "Measure rollout impact",
    detail: "Track whether interventions and experiments actually improved outcomes.",
  },
];

const agentMarks = [
  { name: "Anthropic", sublabel: "Claude Code" },
  { name: "Cursor", sublabel: "Native editor workflows" },
  { name: "Codex", sublabel: "CLI agent runtime" },
  { name: "Gemini", sublabel: "CLI and experimentation" },
];

const chapters = [
  {
    eyebrow: "Workflow intelligence",
    title: "Fingerprint how work actually gets done",
    description:
      "Primer turns noisy sessions into workflow archetypes and fingerprints, then shows which patterns lead to cleaner reviews, stronger merge rates, and better follow-through.",
    bullets: [
      "Compare workflow archetypes by merge rate, review load, findings, and time to merge",
      "See which workflows create quality without overspending",
      "Move from raw transcripts to durable workflow evidence",
    ],
    image: "readme-quality-dark.png",
    caption:
      "Quality becomes much more useful once it is grouped by the workflow patterns behind it.",
  },
  {
    eyebrow: "Cost intelligence",
    title: "See cost through the lens of successful workflows",
    description:
      "FinOps is stronger when it stops treating model spend as the whole story. Primer shows which workflows are efficient, which are expensive but justified, and where teams are overspending without better outcomes.",
    bullets: [
      "Break down spend by workflow archetype and fingerprint",
      "Tie workflow cost to successful outcomes instead of raw activity",
      "Spot where model choice and workflow shape drift apart",
    ],
    image: "readme-finops-dark.png",
    caption:
      "The aha moment is seeing spend clustered around workflows, not just models or people.",
  },
  {
    eyebrow: "Reusable behavior",
    title: "Turn bright spots into exemplars your team can copy",
    description:
      "Primer surfaces reusable prompts, skills, commands, templates, and exemplar sessions so teams can standardize what is already working inside the org.",
    bullets: [
      "Promote strong sessions into bright spots and exemplar libraries",
      "Find underused high-value assets worth spreading to other teams",
      "Coach with evidence instead of generic enablement advice",
    ],
    image: "readme-growth-dark.png",
    caption:
      "Growth becomes concrete when the platform can point at exact sessions and reusable assets worth copying.",
  },
  {
    eyebrow: "Agent stacks",
    title: "Understand the agent stacks behind high performers",
    description:
      "Capture MCPs, skills, commands, templates, delegation, and agent-team modes so you can see which explicit configurations differentiate top performers and which toolchains create friction.",
    bullets: [
      "Separate built-ins from user, repo, and org-defined customizations",
      "Measure toolchain reliability, explicit stacks, and delegation patterns",
      "See when coordinated agent teams outperform solo work",
    ],
    image: "readme-maturity-dark.png",
    caption:
      "Agentic engineering is not just prompts. The stack, orchestration pattern, and reliability all matter.",
  },
  {
    eyebrow: "Measured change",
    title: "Turn recommendations into experiments and measured change",
    description:
      "Primer closes the loop. Recommendations become interventions, interventions become experiments, and the platform measures whether rollouts, playbooks, and model changes actually improved outcomes.",
    bullets: [
      "Track before-and-after changes by team, project, and engineer cohort",
      "Measure whether a playbook or training program moved the needle",
      "Move from insight to operating cadence instead of accumulating dashboards",
    ],
    image: "readme-dashboard-dark.png",
    caption:
      "The product is strongest when teams can turn a recommendation into something they can test and measure.",
  },
];

const audiences = [
  {
    audience: "Engineering leadership",
    summary: "Decide where AI is compounding engineering output and where it is leaking money or quality.",
  },
  {
    audience: "Platform and enablement",
    summary: "See which repo setup, customizations, and agent stacks help engineers move faster.",
  },
  {
    audience: "Team leads and managers",
    summary: "Coach with workflow evidence, exemplars, and concrete experiments instead of instinct alone.",
  },
];
---

<BaseLayout
  title="Primer — Workflow Intelligence for Agentic Engineering"
  description="See which AI workflows actually work. Primer turns session telemetry into workflow intelligence, cost and quality proof, exemplars, and experiments for agentic engineering teams."
>
  <section class="relative overflow-hidden bg-hero-bg text-hero-text">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(129,140,248,0.22),transparent_38%),radial-gradient(circle_at_bottom_right,rgba(99,102,241,0.18),transparent_32%)]"></div>
      <div
        class="absolute inset-0 opacity-55"
        style="background-image: linear-gradient(rgba(129,140,248,0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(129,140,248,0.08) 1px, transparent 1px); background-size: 44px 44px;"
      ></div>
    </div>

    <div class="relative mx-auto max-w-6xl px-6 py-24 md:py-30 lg:py-36">
      <div class="mx-auto max-w-4xl text-center">
        <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/8 px-4 py-1.5 text-sm text-white/75 animate-fade-in-up">
          <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
          Open source workflow intelligence for agentic engineering
        </div>
        <h1 class="font-display mb-6 text-4xl tracking-tight md:text-5xl lg:text-7xl animate-fade-in-up" style="--delay: 80ms">
          See which AI workflows
          <span class="text-primer-400"> actually work</span>
        </h1>
        <p class="mx-auto mb-10 max-w-3xl text-lg leading-relaxed text-white/68 md:text-xl animate-fade-in-up" style="--delay: 160ms">
          Primer captures work across Claude Code, Cursor, Codex CLI, and Gemini CLI, then turns
          that telemetry into workflow fingerprints, quality attribution, cost proof, exemplars,
          and experiments your team can standardize.
        </p>
        <div class="mb-8 flex flex-col items-center justify-center gap-4 sm:flex-row animate-fade-in-up" style="--delay: 240ms">
          <a
            href={`${import.meta.env.BASE_URL}docs/`}
            class="inline-flex items-center rounded-lg bg-primer-brand px-6 py-3 font-medium text-white transition-colors hover:bg-primer-600"
          >
            Read the docs
          </a>
          <a
            href={`${import.meta.env.BASE_URL}#tour`}
            class="inline-flex items-center rounded-lg border border-white/15 bg-white/8 px-6 py-3 font-medium text-white transition-colors hover:bg-white/12"
          >
            See how it works
          </a>
        </div>
        <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm text-white/50 animate-fade-in-up" style="--delay: 320ms">
          {heroChips.map((chip, idx) => (
            <div class="flex items-center gap-4">
              <span class="uppercase tracking-[0.18em]">{chip}</span>
              {idx < heroChips.length - 1 && <span class="hidden sm:inline-block h-1 w-1 rounded-full bg-white/22"></span>}
            </div>
          ))}
        </div>
      </div>

      <div class="mt-14 animate-fade-in-up" style="--delay: 400ms">
        <TerminalAnimation client:visible />
      </div>
    </div>
  </section>

  <section id="proof" class="border-y border-border bg-background py-8">
    <div class="mx-auto grid max-w-6xl gap-4 px-6 md:grid-cols-2 xl:grid-cols-4">
      {proofSignals.map((signal, idx) => (
        <div
          class="rounded-2xl border border-border/80 bg-card/70 px-5 py-4 animate-fade-in-up"
          style={`--delay: ${idx * 70}ms`}
        >
          <p class="mb-1 text-sm font-semibold">{signal.label}</p>
          <p class="text-sm leading-relaxed text-muted-foreground">{signal.detail}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="agent-atmosphere relative overflow-hidden bg-hero-bg text-hero-text">
    <div class="mx-auto grid max-w-6xl items-center gap-10 px-6 py-20 md:py-24 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="relative z-10 max-w-3xl">
        <h2 class="font-display mb-4 text-3xl tracking-tight md:text-5xl">
          Primer stays credible across the agent stack
        </h2>
        <p class="max-w-2xl text-lg leading-relaxed text-white/66">
          Claude Code, Cursor, Codex CLI, and Gemini CLI all move quickly and emit different kinds
          of evidence. Primer is built around source-aware trust, so cross-agent analytics stay
          comparable instead of collapsing into false precision.
        </p>
      </div>

      <div class="agent-cluster hidden lg:grid lg:grid-cols-2" aria-hidden="true">
        {agentMarks.map((mark) => (
          <div class="agent-cluster__mark">
            <span class="agent-cluster__name">{mark.name}</span>
            <span class="agent-cluster__sub">{mark.sublabel}</span>
          </div>
        ))}
      </div>

      <div class="mt-8 grid gap-3 lg:hidden">
        {agentMarks.map((mark) => (
          <div class="agent-cluster__mark">
            <span class="agent-cluster__name">{mark.name}</span>
            <span class="agent-cluster__sub">{mark.sublabel}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="tour" class="py-18 md:py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-16 max-w-3xl">
        <h2 class="font-display mb-4 text-3xl tracking-tight md:text-5xl">
          From workflow proof to measured change
        </h2>
        <p class="text-lg leading-relaxed text-muted-foreground">
          Each section below shows a different layer of evidence Primer turns into an operating
          decision.
        </p>
      </div>
    </div>

    <div class="space-y-18 md:space-y-24">
      {chapters.map((chapter, idx) => (
        <section class={idx % 2 === 1 ? "bg-muted/45 py-18 md:py-22" : "py-18 md:py-22"}>
          <div
            class={`mx-auto grid max-w-6xl items-center gap-10 px-6 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] ${
              idx % 2 === 1 ? "lg:[&>*:first-child]:order-2 lg:[&>*:last-child]:order-1" : ""
            }`}
          >
            <div class="space-y-6">
              <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primer-brand">{chapter.eyebrow}</p>
              <h3 class="font-display text-3xl tracking-tight md:text-4xl">{chapter.title}</h3>
              <p class="text-lg leading-relaxed text-muted-foreground">{chapter.description}</p>
              <ul class="space-y-3 text-sm leading-relaxed text-foreground/90">
                {chapter.bullets.map((bullet) => (
                  <li class="flex gap-3">
                    <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-primer-brand"></span>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="story-frame animate-fade-in-up" style={`--delay: ${idx * 70}ms`}>
              <div class="story-frame__ornament"></div>
              <div class="story-frame__header">
                <span></span>
                <span></span>
                <span></span>
              </div>
              <img
                src={`${import.meta.env.BASE_URL}screenshots/${chapter.image}`}
                alt={chapter.caption}
                class="story-frame__image"
                loading="lazy"
              />
              <p class="story-frame__caption">{chapter.caption}</p>
            </div>
          </div>
        </section>
      ))}
    </div>
  </section>

  <section class="bg-muted/50 py-18 md:py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-12 text-center">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-primer-brand">Who it is for</p>
        <h2 class="font-display mb-4 text-3xl tracking-tight md:text-4xl">
          One product, three kinds of operating decisions
        </h2>
      </div>

      <div class="grid gap-6 lg:grid-cols-3">
        {audiences.map((group, idx) => (
          <div
            class="rounded-2xl border border-border bg-card p-6 shadow-sm animate-fade-in-up"
            style={`--delay: ${idx * 80}ms`}
          >
            <h3 class="mb-3 font-display text-2xl tracking-tight">{group.audience}</h3>
            <p class="text-sm leading-relaxed text-muted-foreground">{group.summary}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-hero-bg py-18 text-hero-text md:py-24">
    <div class="mx-auto max-w-5xl px-6 text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-primer-400">Get started</p>
      <h2 class="font-display mb-4 text-3xl tracking-tight md:text-5xl">
        Build your workflow intelligence layer on your own infrastructure
      </h2>
      <p class="mx-auto mb-8 max-w-2xl text-lg leading-relaxed text-white/68">
        Self-host Primer, connect your agents and GitHub data, and start seeing which workflows,
        assets, agent stacks, and experiments are worth standardizing.
      </p>
      <div class="mb-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={`${import.meta.env.BASE_URL}docs/installation/`}
          class="inline-flex items-center rounded-lg bg-primer-brand px-6 py-3 font-medium text-white transition-colors hover:bg-primer-600"
        >
          Install Primer
        </a>
        <a
          href="https://github.com/ccf/primer"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center rounded-lg border border-white/15 bg-white/8 px-6 py-3 font-medium text-white transition-colors hover:bg-white/12"
        >
          Explore the repo
        </a>
      </div>
      <p class="text-sm text-white/52">Open source. Self-hosted. Privacy-first.</p>
    </div>
  </section>
</BaseLayout>
