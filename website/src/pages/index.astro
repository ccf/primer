---
import BaseLayout from "../layouts/BaseLayout.astro";
import TerminalAnimation from "../components/TerminalAnimation";

const features = [
  {
    title: "Usage Dashboard",
    description: "Track sessions, tokens, costs, and tool usage across your entire engineering team with real-time analytics.",
    icon: "M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z",
  },
  {
    title: "Cost Analysis",
    description: "Per-engineer and per-model cost breakdowns with trend analysis. Know exactly where your AI budget goes.",
    icon: "M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  },
  {
    title: "Friction Detection",
    description: "Automatically identify workflow bottlenecks, permission denials, and tool failures that slow your team down.",
    icon: "M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z",
  },
  {
    title: "MCP Sidecar",
    description: "Real-time insights directly inside Claude Code via Model Context Protocol. No context switching needed.",
    icon: "M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.686-5.747l4.5-4.5a4.5 4.5 0 016.364 6.364l-1.757 1.757",
  },
  {
    title: "Multi-Agent Support",
    description: "Track Claude Code, Codex CLI, and Gemini CLI from a single dashboard. More agents coming soon.",
    icon: "M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z",
  },
  {
    title: "GitHub Integration",
    description: "Link sessions to pull requests automatically. See the AI contribution story behind every PR.",
    icon: "M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z",
  },
];
---

<BaseLayout>
  <!-- Hero -->
  <section class="relative bg-hero-bg text-hero-text overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-20 left-1/4 w-96 h-96 bg-primer-brand/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 right-1/4 w-64 h-64 bg-primer-brand/10 rounded-full blur-3xl"></div>
      <!-- Dot grid pattern -->
      <div class="absolute inset-0" style="background-image: radial-gradient(circle, rgba(99,102,241,0.12) 1px, transparent 1px); background-size: 32px 32px;"></div>
    </div>

    <div class="relative max-w-6xl mx-auto px-6 py-24 md:py-32 lg:py-40">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 text-sm text-white/70 mb-8 animate-fade-in-up">
          <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
          Open source &middot; Self-hosted &middot; Privacy-first
        </div>
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl tracking-tight mb-6 animate-fade-in-up" style="--delay: 80ms">
          See how your team uses<br />
          <span class="text-primer-400">AI coding tools</span>
        </h1>
        <p class="text-lg md:text-xl text-white/60 max-w-2xl mx-auto mb-10 animate-fade-in-up" style="--delay: 160ms">
          Aggregate usage insights across Claude Code, Codex CLI, and Gemini CLI.
          Track costs, detect friction, and accelerate AI adoption across your engineering org.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up" style="--delay: 240ms">
          <a
            href={`${import.meta.env.BASE_URL}docs/`}
            class="inline-flex items-center px-6 py-3 rounded-lg bg-primer-brand text-white font-medium hover:bg-primer-600 transition-colors"
          >
            Get Started
          </a>
          <a
            href="https://github.com/ccf/primer"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-white/10 text-white font-medium hover:bg-white/15 transition-colors"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            View on GitHub
          </a>
        </div>
      </div>

      <!-- Terminal animation -->
      <div class="animate-fade-in-up" style="--delay: 320ms">
        <TerminalAnimation client:visible />
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-display text-3xl md:text-4xl tracking-tight mb-4">
          Everything you need to understand AI usage
        </h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          From individual sessions to organization-wide trends, Primer gives you
          complete visibility into how your team works with AI.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((feature, idx) => (
          <div
            class="group p-6 rounded-2xl border border-border bg-card hover:border-primer-border hover:shadow-lg transition-all duration-200 animate-fade-in-up"
            style={`--delay: ${idx * 80}ms`}
          >
            <div class="w-10 h-10 rounded-lg bg-primer-surface flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-primer-brand" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d={feature.icon} />
              </svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">{feature.title}</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-24 md:py-32 bg-muted/50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-display text-3xl md:text-4xl tracking-tight mb-4">
          How it works
        </h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          Three components that work together to give you complete visibility.
        </p>
      </div>

      <div class="relative grid md:grid-cols-3 gap-8">
        <!-- Connector line between steps (visible on md+) -->
        <div class="hidden md:block absolute top-6 left-[16.67%] right-[16.67%] h-px border-t-2 border-dashed border-primer-brand/30"></div>

        <div class="relative text-center animate-fade-in-up" style="--delay: 0ms">
          <div class="w-12 h-12 rounded-full bg-primer-brand text-white flex items-center justify-center text-lg font-semibold mx-auto mb-4 relative z-10">1</div>
          <h3 class="font-semibold text-lg mb-2">Hook captures sessions</h3>
          <p class="text-sm text-muted-foreground">
            A lightweight hook runs at the end of each Claude Code, Codex CLI, or Gemini CLI session, extracting metadata and sending it to your server.
          </p>
        </div>
        <div class="relative text-center animate-fade-in-up" style="--delay: 100ms">
          <div class="w-12 h-12 rounded-full bg-primer-brand text-white flex items-center justify-center text-lg font-semibold mx-auto mb-4 relative z-10">2</div>
          <h3 class="font-semibold text-lg mb-2">Server aggregates data</h3>
          <p class="text-sm text-muted-foreground">
            The self-hosted server processes sessions, computes costs, detects friction patterns, and links sessions to GitHub PRs.
          </p>
        </div>
        <div class="relative text-center animate-fade-in-up" style="--delay: 200ms">
          <div class="w-12 h-12 rounded-full bg-primer-brand text-white flex items-center justify-center text-lg font-semibold mx-auto mb-4 relative z-10">3</div>
          <h3 class="font-semibold text-lg mb-2">Dashboard shows insights</h3>
          <p class="text-sm text-muted-foreground">
            The React dashboard and MCP sidecar give you real-time analytics — from individual sessions to org-wide trends.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Install CTA -->
  <section class="py-24 md:py-32">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display text-3xl md:text-4xl tracking-tight mb-4">
        Get started in minutes
      </h2>
      <p class="text-lg text-muted-foreground mb-10">
        Self-hosted. Your data stays on your infrastructure.
      </p>

      <div class="bg-hero-bg rounded-xl p-6 text-left font-mono text-sm mb-10">
        <div class="flex items-center gap-2 mb-4 text-white/40 text-xs">
          <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
          <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
          <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
        </div>
        <pre class="text-white/80 whitespace-pre"><span class="text-primer-brand">$</span> pip install primer-io
<span class="text-primer-brand">$</span> primer init
<span class="text-primer-brand">$</span> primer server start
<span class="text-primer-brand">$</span> primer hook install</pre>
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`${import.meta.env.BASE_URL}docs/`}
          class="inline-flex items-center px-6 py-3 rounded-lg bg-primer-brand text-white font-medium hover:bg-primer-600 transition-colors"
        >
          Read the Docs
        </a>
        <a
          href="https://github.com/ccf/primer"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-border text-foreground font-medium hover:bg-muted transition-colors"
        >
          View on GitHub
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
