---
import BaseLayout from "../layouts/BaseLayout.astro";
import TerminalAnimation from "../components/TerminalAnimation";

const heroChips = [
  "Workflow fingerprints",
  "Quality attribution",
  "Cost per successful outcome",
  "Exemplar sessions",
];

const proofPoints = [
  {
    eyebrow: "Workflow intelligence",
    title: "See which AI workflows actually work.",
    description:
      "Primer fingerprints sessions into repeatable workflows, then shows which patterns are associated with better quality, faster merges, and lower cost per success.",
  },
  {
    eyebrow: "Customization intelligence",
    title: "Understand what engineers configure differently.",
    description:
      "Track MCPs, skills, commands, subagents, and templates by provenance, state, reliability, and outcome so you can separate explicit choices from defaults.",
  },
  {
    eyebrow: "Multi-agent orchestration",
    title: "Measure delegation and agent-team patterns.",
    description:
      "Capture delegation graphs, classify agent-team modes, and learn when coordinated multi-agent work outperforms solo sessions.",
  },
  {
    eyebrow: "Operational proof",
    title: "Turn recommendations into experiments.",
    description:
      "Promote promising workflows, models, and enablement changes into structured experiments, then measure whether the rollout actually improved outcomes.",
  },
];

const screenshots = [
  {
    name: "Workflow Cost Attribution",
    image: "readme-finops-dark.png",
    caption:
      "Break down spend by workflow archetype and fingerprint instead of looking at model bills in isolation.",
  },
  {
    name: "Workflow Quality Attribution",
    image: "readme-quality-dark.png",
    caption:
      "Connect workflow patterns to merge rate, review findings, review load, and time to merge.",
  },
  {
    name: "Growth and Exemplars",
    image: "readme-growth-dark.png",
    caption:
      "Surface bright spots, exemplar sessions, reusable assets, and team skill gaps worth acting on.",
  },
  {
    name: "Agent Stacks and Reliability",
    image: "readme-maturity-dark.png",
    caption:
      "See which customizations, toolchains, and agent-team modes top performers use and which ones create friction.",
  },
];

const workflowLoop = [
  {
    step: "Capture",
    title: "Collect multi-agent evidence",
    description:
      "Hooks, sync, and imports ingest Claude Code, Cursor, Codex CLI, and Gemini CLI sessions alongside PRs, review findings, and repo context.",
  },
  {
    step: "Normalize",
    title: "Build a trustworthy semantic layer",
    description:
      "Primer derives workflows, recovery paths, change shape, customization state, delegation graphs, and source-aware integrity signals.",
  },
  {
    step: "Surface",
    title: "Show evidence by persona",
    description:
      "Engineering leaders, platform teams, leads, and engineers each get the views they need across quality, cost, growth, maturity, and projects.",
  },
  {
    step: "Act",
    title: "Standardize what works",
    description:
      "Promote bright spots into playbooks, exemplars, model guidance, and experiments instead of leaving the signal trapped in dashboards.",
  },
  {
    step: "Measure",
    title: "Verify what changed",
    description:
      "Track whether rollouts, interventions, and experiments improved quality, reduced friction, or lowered cost per successful outcome.",
  },
];

const audiences = [
  {
    audience: "Engineering leadership",
    summary: "Decide where AI is paying off and where it is leaking money or quality.",
    bullets: [
      "Which workflows deliver the best quality per dollar",
      "Which teams have figured out reusable high-performing patterns",
      "Which experiments and rollout changes are improving outcomes",
    ],
  },
  {
    audience: "Platform and enablement teams",
    summary: "See where repo setup, tooling, and agent configuration help or hurt engineers.",
    bullets: [
      "Which customizations and MCP stacks top performers rely on",
      "Which toolchains are brittle, underused, or worth standardizing",
      "Which projects need workflow playbooks, skills, or repo enablement next",
    ],
  },
  {
    audience: "Team leads and managers",
    summary: "Coach teams with evidence instead of intuition.",
    bullets: [
      "Which prompt patterns, assets, and exemplars are worth copying",
      "Which teams have workflow or skill gaps by project context",
      "Which engineers should try a different model or delegation pattern next",
    ],
  },
];

const differentiators = [
  {
    title: "Not just usage tracking",
    description:
      "Primer links workflow fingerprint -> quality -> cost -> intervention so you can decide what to standardize, not just count sessions.",
  },
  {
    title: "Not Claude-only analytics",
    description:
      "The platform is built for cross-agent intelligence across Claude Code, Cursor, Codex CLI, and Gemini CLI with capability-aware trust boundaries.",
  },
  {
    title: "Not just prompts and transcripts",
    description:
      "It models customizations, delegation, reliability, reusable assets, and project context so the data reflects how agentic engineering actually works.",
  },
  {
    title: "Not just dashboards",
    description:
      "Primer closes the loop with recommendations, interventions, experiments, and before-and-after measurement.",
  },
];
---

<BaseLayout
  title="Primer — Workflow Intelligence for Agentic Engineering"
  description="See which AI workflows actually work. Primer turns session telemetry into workflow intelligence, cost and quality proof, exemplars, and experiments for agentic engineering teams."
>
  <section class="relative overflow-hidden bg-hero-bg text-hero-text">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(129,140,248,0.22),transparent_38%),radial-gradient(circle_at_bottom_right,rgba(99,102,241,0.18),transparent_32%)]"></div>
      <div
        class="absolute inset-0 opacity-60"
        style="background-image: linear-gradient(rgba(129,140,248,0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(129,140,248,0.08) 1px, transparent 1px); background-size: 44px 44px;"
      ></div>
    </div>

    <div class="relative mx-auto max-w-6xl px-6 py-24 md:py-30 lg:py-36">
      <div class="mx-auto max-w-4xl text-center">
        <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/8 px-4 py-1.5 text-sm text-white/75 animate-fade-in-up">
          <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
          Workflow intelligence for agentic engineering
        </div>
        <h1 class="font-display mb-6 text-4xl tracking-tight md:text-5xl lg:text-7xl animate-fade-in-up" style="--delay: 80ms">
          See which AI workflows
          <span class="text-primer-400"> actually work</span>
        </h1>
        <p class="mx-auto mb-10 max-w-3xl text-lg leading-relaxed text-white/68 md:text-xl animate-fade-in-up" style="--delay: 160ms">
          Primer captures work across Claude Code, Cursor, Codex CLI, and Gemini CLI, then turns
          that telemetry into workflow fingerprints, quality attribution, cost proof, exemplars,
          and experiments your team can standardize.
        </p>
        <div class="mb-8 flex flex-col items-center justify-center gap-4 sm:flex-row animate-fade-in-up" style="--delay: 240ms">
          <a
            href={`${import.meta.env.BASE_URL}docs/`}
            class="inline-flex items-center rounded-lg bg-primer-brand px-6 py-3 font-medium text-white transition-colors hover:bg-primer-600"
          >
            Read the docs
          </a>
          <a
            href={`${import.meta.env.BASE_URL}#proof`}
            class="inline-flex items-center rounded-lg border border-white/15 bg-white/8 px-6 py-3 font-medium text-white transition-colors hover:bg-white/12"
          >
            See the workflow proof
          </a>
        </div>
        <div class="flex flex-wrap items-center justify-center gap-2 animate-fade-in-up" style="--delay: 320ms">
          {heroChips.map((chip) => (
            <span class="rounded-full border border-white/12 bg-white/6 px-3 py-1 text-xs uppercase tracking-[0.18em] text-white/62">
              {chip}
            </span>
          ))}
        </div>
      </div>

      <div class="mt-14 animate-fade-in-up" style="--delay: 400ms">
        <TerminalAnimation client:visible />
      </div>
    </div>
  </section>

  <section id="proof" class="py-18 md:py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-14 max-w-3xl">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-primer-brand">Core proof</p>
        <h2 class="font-display mb-4 text-3xl tracking-tight md:text-4xl">
          Primer is becoming the intelligence layer for agentic engineering.
        </h2>
        <p class="text-lg text-muted-foreground">
          The product is strongest when it links behavior to outcomes. These are the proof points
          that now define the platform.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {proofPoints.map((point, idx) => (
          <div
            class="rounded-2xl border border-border bg-card p-6 shadow-sm transition-all duration-200 hover:border-primer-border hover:shadow-lg animate-fade-in-up"
            style={`--delay: ${idx * 80}ms`}
          >
            <p class="mb-3 text-xs font-semibold uppercase tracking-[0.22em] text-primer-brand">{point.eyebrow}</p>
            <h3 class="mb-3 font-display text-2xl tracking-tight">{point.title}</h3>
            <p class="text-sm leading-relaxed text-muted-foreground">{point.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-muted/50 py-18 md:py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-12 text-center">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-primer-brand">Screens that prove it</p>
        <h2 class="font-display mb-4 text-3xl tracking-tight md:text-4xl">
          Cost, quality, exemplars, and agent stacks in one product story
        </h2>
        <p class="mx-auto max-w-2xl text-lg text-muted-foreground">
          These are the views that show how Primer connects spend, outcomes, reusable behavior,
          and coaching across the product.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {screenshots.map((view, idx) => (
          <div
            class="group overflow-hidden rounded-2xl border border-border bg-card shadow-sm transition-all duration-200 hover:border-primer-border hover:shadow-lg animate-fade-in-up"
            style={`--delay: ${idx * 70}ms`}
          >
            <div class="aspect-[16/10] overflow-hidden bg-[#111827]">
              <img
                src={`${import.meta.env.BASE_URL}screenshots/${view.image}`}
                alt={view.caption}
                class="h-full w-full object-cover object-top opacity-92 transition-transform duration-300 group-hover:scale-[1.01] group-hover:opacity-100"
                loading="lazy"
              />
            </div>
            <div class="p-5">
              <h3 class="mb-2 text-lg font-semibold">{view.name}</h3>
              <p class="text-sm leading-relaxed text-muted-foreground">{view.caption}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-18 md:py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-14 max-w-3xl">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-primer-brand">Product loop</p>
        <h2 class="font-display mb-4 text-3xl tracking-tight md:text-4xl">
          From raw sessions to decisions your team can act on
        </h2>
        <p class="text-lg text-muted-foreground">
          The product loop matters as much as the metrics: capture, normalize, surface, act, and
          measure what changed.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-5">
        {workflowLoop.map((item, idx) => (
          <div
            class="rounded-2xl border border-border bg-card p-6 animate-fade-in-up"
            style={`--delay: ${idx * 90}ms`}
          >
            <div class="mb-4 flex items-center gap-3">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-primer-surface text-sm font-semibold text-primer-brand">
                {idx + 1}
              </span>
              <span class="text-xs font-semibold uppercase tracking-[0.22em] text-muted-foreground">{item.step}</span>
            </div>
            <h3 class="mb-2 text-lg font-semibold">{item.title}</h3>
            <p class="text-sm leading-relaxed text-muted-foreground">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="features" class="bg-muted/50 py-18 md:py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-12 text-center">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-primer-brand">Who it is for</p>
        <h2 class="font-display mb-4 text-3xl tracking-tight md:text-4xl">
          Different questions, one intelligence layer
        </h2>
      </div>

      <div class="grid gap-6 lg:grid-cols-3">
        {audiences.map((group, idx) => (
          <div
            class="rounded-2xl border border-border bg-card p-6 animate-fade-in-up"
            style={`--delay: ${idx * 90}ms`}
          >
            <h3 class="mb-3 font-display text-2xl tracking-tight">{group.audience}</h3>
            <p class="mb-5 text-sm leading-relaxed text-muted-foreground">{group.summary}</p>
            <ul class="space-y-3 text-sm text-foreground/90">
              {group.bullets.map((bullet) => (
                <li class="flex gap-3">
                  <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-primer-brand"></span>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-18 md:py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-12 max-w-3xl">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-primer-brand">Why Primer</p>
        <h2 class="font-display mb-4 text-3xl tracking-tight md:text-4xl">
          Workflow intelligence, not generic AI analytics
        </h2>
        <p class="text-lg text-muted-foreground">
          Plenty of tools can tell you that AI usage went up. Primer is built to show what should
          change next.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {differentiators.map((item, idx) => (
          <div
            class="rounded-2xl border border-border bg-card p-6 shadow-sm animate-fade-in-up"
            style={`--delay: ${idx * 80}ms`}
          >
            <h3 class="mb-3 text-lg font-semibold">{item.title}</h3>
            <p class="text-sm leading-relaxed text-muted-foreground">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-hero-bg py-18 text-hero-text md:py-24">
    <div class="mx-auto max-w-5xl px-6 text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-primer-400">Get started</p>
      <h2 class="font-display mb-4 text-3xl tracking-tight md:text-5xl">
        Build your workflow intelligence layer on your own infrastructure
      </h2>
      <p class="mx-auto mb-8 max-w-2xl text-lg leading-relaxed text-white/68">
        Self-host Primer, connect your agents and GitHub data, and start seeing which workflows,
        assets, and agent stacks are worth standardizing.
      </p>
      <div class="mb-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={`${import.meta.env.BASE_URL}docs/installation/`}
          class="inline-flex items-center rounded-lg bg-primer-brand px-6 py-3 font-medium text-white transition-colors hover:bg-primer-600"
        >
          Install Primer
        </a>
        <a
          href="https://github.com/ccf/primer"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center rounded-lg border border-white/15 bg-white/8 px-6 py-3 font-medium text-white transition-colors hover:bg-white/12"
        >
          Explore the repo
        </a>
      </div>
      <p class="text-sm text-white/52">Open source. Self-hosted. Privacy-first.</p>
    </div>
  </section>
</BaseLayout>
