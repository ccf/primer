---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;

const captures = ["Claude Code", "Cursor", "Codex CLI", "Gemini CLI"];

const chapters = [
  {
    num: "Chapter II",
    title: "Fingerprint how work <em>actually</em> gets done.",
    body: "Primer turns noisy sessions into workflow archetypes and fingerprints, then shows which patterns lead to cleaner reviews, stronger merge rates, and better follow-through. It is less a dashboard than a ledger of how your team thinks.",
    bullets: [
      "Compare workflow archetypes by merge rate, review load, findings, and time to merge.",
      "See which workflows create quality without overspending.",
      "Move from raw transcripts to durable workflow evidence.",
    ],
    plate: "screenshots/readme-quality-dark.png",
    caption: "Plate I. Quality clustered by workflow archetype.",
    layout: "right",
  },
  {
    num: "Chapter III",
    title: "See cost through the <em>lens</em> of successful workflows.",
    body: "FinOps becomes useful only when it stops treating model spend as the whole story. Primer shows which workflows are efficient, which are expensive but justified, and where teams are overspending without better outcomes.",
    bullets: [
      "Break down spend by workflow archetype and fingerprint.",
      "Tie cost to successful outcomes instead of raw activity.",
      "Spot when model choice and workflow shape drift apart.",
    ],
    plate: "screenshots/readme-finops-dark.png",
    caption: "Plate II. Spend grouped by archetype, not by model.",
    layout: "left",
  },
  {
    num: "Chapter IV",
    title: "Turn bright spots into <em>exemplars</em> your team can copy.",
    body: "Primer surfaces reusable prompts, skills, commands, templates, and exemplar sessions so teams can standardize what is already working inside the org — coaching with evidence, not generic enablement advice.",
    bullets: [
      "Promote strong sessions into bright spots and exemplar libraries.",
      "Find underused high-value assets worth spreading to other teams.",
      "Coach with evidence instead of generic enablement advice.",
    ],
    plate: "screenshots/readme-growth-dark.png",
    caption: "Plate III. A bright spot promoted into an exemplar.",
    layout: "right",
  },
];

const metrics = [
  { k: "Sessions captured",    v: "4,947", d: "across Claude, Cursor, Codex, Gemini" },
  { k: "Success rate",         v: "96",    suffix: "%", accent: true, d: "+4.1 after intervention" },
  { k: "Median time to merge", v: "7.1",   suffix: "h", d: "−37% versus Q3 baseline" },
  { k: "Cost per success",     v: "$0.41", d: "−22% after playbook rollout" },
];

const faqs = [
  {
    q: "What is Primer?",
    a: "Primer is an open-source workflow intelligence platform for agentic engineering teams. It captures session data from Claude Code, Cursor, Codex CLI, and Gemini CLI and turns it into workflow fingerprints, cost and quality proof, exemplar libraries, and measurable experiments — so you can decide which AI coding patterns actually work in your org.",
  },
  {
    q: "Which AI coding tools does Primer support?",
    a: "Primer supports Claude Code, Cursor, Codex CLI, and Gemini CLI today. The capture layer is a pluggable extractor registry, so additional agents can be added without changing the analytics pipeline.",
  },
  {
    q: "How is this different from generic AI usage tracking?",
    a: "Most tools count tokens, sessions, or accepted suggestions. Primer ties workflow patterns to outcomes — PR merge rate, review comments, post-merge quality, friction recovery, and cost per successful change — so you can compare what high performers do differently from struggling engineers and standardize the patterns that work.",
  },
  {
    q: "Is Primer self-hosted?",
    a: "Yes. Primer is open source under MIT, runs on your own infrastructure, and stores all data in your own PostgreSQL database. Telemetry never leaves your network. You can deploy it via Docker Compose, Helm, or directly with pip.",
  },
  {
    q: "Can I try Primer without installing anything?",
    a: "Yes — demo.useprimer.dev is a live read-only instance pre-loaded with a fictional 25-engineer org so you can explore every dashboard before installing.",
  },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "Primer",
    applicationCategory: "DeveloperApplication",
    applicationSubCategory: "Engineering Analytics",
    operatingSystem: "Linux, macOS, Windows",
    description:
      "Open-source workflow intelligence for agentic engineering. Captures sessions from Claude Code, Cursor, Codex CLI, and Gemini CLI and turns them into workflow fingerprints, quality attribution, cost proof, exemplars, and experiments.",
    url: "https://useprimer.dev",
    sameAs: ["https://github.com/ccf/primer"],
    license: "https://opensource.org/licenses/MIT",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    softwareHelp: { "@type": "CreativeWork", url: "https://useprimer.dev/docs/" },
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Primer",
    url: "https://useprimer.dev",
    logo: "https://useprimer.dev/logo-mark.svg",
    sameAs: ["https://github.com/ccf/primer"],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
      "@type": "Question",
      name: faq.q,
      acceptedAnswer: { "@type": "Answer", text: faq.a },
    })),
  },
];
---

<BaseLayout
  title="Primer — Workflow Intelligence for Agentic Engineering"
  description="See which AI workflows actually work. Primer turns session telemetry into workflow intelligence, cost and quality proof, exemplars, and experiments for agentic engineering teams."
  structuredData={structuredData}
>
  <!-- ─── Chapter I — The Primer ─────────────────────── -->
  <section class="hero">
    <div class="hero-inner">
      <div class="eyebrow reveal" style="--delay: 0ms"><span>Chapter I &nbsp;·&nbsp; The Primer</span></div>

      <h1 class="hero-title reveal" style="--delay: 80ms">
        See which<br>
        AI workflows<br>
        <em>actually work.</em>
      </h1>

      <p class="hero-lede has-dropcap reveal" style="--delay: 180ms">
        Primer reads the working notes of your engineering team — every session with Claude Code, Cursor, Codex and Gemini — and quietly turns that telemetry into fingerprints, quality attribution, cost proof, exemplars, and measurable experiments.
      </p>

      <div class="hero-actions reveal" style="--delay: 260ms">
        <a href="https://demo.useprimer.dev" class="btn-ink">
          <span>Try the live demo</span>
          <span aria-hidden="true">→</span>
        </a>
        <a href={`${base}docs/`} class="link-quiet">Read the field guide</a>
      </div>

      <hr class="hairline" />

      <div class="captures reveal" style="--delay: 340ms">
        <span class="captures-label">Captures</span>
        {captures.map((name, i) => (
          <>
            <span class="captures-name">{name}</span>
            {i < captures.length - 1 && <span class="captures-dot">·</span>}
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Chapters II – IV ───────────────────────────── -->
  {chapters.map((chapter) => (
    <section class="chapter">
      <div class="chapter-inner">
        <div class="chapter-header">
          <div class="chapter-num">{chapter.num}</div>
          <h2 class="chapter-title" set:html={chapter.title} />
        </div>

        <div class={`chapter-body chapter-body--${chapter.layout}`}>
          <div class="chapter-spacer"></div>
          <div class="chapter-text">
            <p class="chapter-lede">{chapter.body}</p>
            <ul class="chapter-bullets">
              {chapter.bullets.map((b) => <li>{b}</li>)}
            </ul>
          </div>
          <figure class="chapter-plate">
            <div class="chapter-plate-frame">
              <img src={`${base}${chapter.plate}`} alt={chapter.caption} loading="lazy" width="1440" height="900" />
            </div>
            <figcaption class="chapter-plate-caption">{chapter.caption}</figcaption>
          </figure>
        </div>
      </div>
    </section>
  ))}

  <!-- ─── Technical Interlude (dark) ─────────────────── -->
  <section class="interlude">
    <div class="interlude-inner">
      <div class="interlude-header">
        <div class="eyebrow eyebrow--dark"><span>Technical interlude</span></div>
        <h2 class="interlude-title">
          The platform is <em>evidence-forward.</em><br>
          Every metric is a trail back to the<br>sessions that earned it.
        </h2>
      </div>

      <div class="telemetry">
        <p class="telemetry-lede">A live snapshot from the public demo instance, updated as sessions arrive.</p>

        <div>
          <div class="telemetry-panel">
            <div class="telemetry-panel-header">
              <div class="telemetry-panel-title">Primer · live instance</div>
              <div class="telemetry-panel-meta">
                <span class="telemetry-dot pulse-dot"></span>
                Synchronised 2s ago
              </div>
            </div>

            <div class="telemetry-grid">
              {metrics.map((m) => (
                <div class="telemetry-cell">
                  <div class="telemetry-k">{m.k}</div>
                  <div class={`telemetry-v ${m.accent ? "telemetry-v--accent" : ""}`}>
                    {m.v}
                    {m.suffix && <sup>{m.suffix}</sup>}
                  </div>
                  <div class="telemetry-d">{m.d}</div>
                </div>
              ))}
            </div>

            <div class="telemetry-panel-footer">
              <span>primer / demo.useprimer.dev</span>
              <span class="telemetry-cursor">▊</span>
            </div>
          </div>
          <div class="chapter-plate-caption chapter-plate-caption--dark">
            Plate IV. Selected metrics from the open demo.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Pull quote ─────────────────────────────────── -->
  <section class="pullquote">
    <div class="pullquote-inner">
      <div class="pullquote-mark">&ldquo;</div>
      <q>
        Knowing which engineers ship more is easy. Knowing <em>how</em> they think, which patterns matter, and which assets to copy across the org — that is the question Primer is written to answer.
      </q>
      <div class="pullquote-attrib">— From the Primer field guide</div>
    </div>
  </section>

  <!-- ─── FAQ as editorial Q&A ───────────────────────── -->
  <section id="faq" class="faq">
    <div class="faq-inner">
      <div class="chapter-header">
        <div class="chapter-num">Apparatus</div>
        <h2 class="chapter-title">Common questions, briefly answered.</h2>
      </div>
      <dl class="faq-list">
        {faqs.map((faq) => (
          <div class="faq-item">
            <dt>{faq.q}</dt>
            <dd>{faq.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- ─── Colophon (final CTA) ───────────────────────── -->
  <section class="colophon">
    <div class="colophon-inner">
      <div class="eyebrow eyebrow--dark"><span>Colophon</span></div>
      <div>
        <h2 class="colophon-title">
          Open source. Self-hosted.<br>
          <em>Your own infrastructure.</em>
        </h2>
        <p class="colophon-lede">
          Primer is MIT-licensed and runs on your own Postgres. Telemetry never leaves your network. Install with a single command, connect your agents and GitHub data, and begin the study.
        </p>
        <div class="colophon-actions">
          <a href="https://demo.useprimer.dev" class="btn-paper">
            <span>Try the live demo</span>
            <span aria-hidden="true">→</span>
          </a>
          <a href={`${base}docs/installation/`} class="link-quiet link-quiet--dark">Install Primer</a>
          <a href="https://github.com/ccf/primer" target="_blank" rel="noopener" class="link-quiet link-quiet--dark">View on GitHub</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ─── Hero ─────────────────────────────────────────── */
  .hero {
    background: var(--color-paper);
  }
  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 100px 48px 80px;
  }
  .hero-title {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(56px, 9vw, 120px);
    line-height: 0.92;
    letter-spacing: -0.035em;
    color: var(--color-ink);
    max-width: 13ch;
    margin: 40px 0 48px;
    font-variation-settings: "opsz" 144, "SOFT" 50;
  }
  .hero-title em {
    font-style: italic;
    font-weight: 400;
    color: var(--color-accent);
  }
  .hero-lede {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 22px;
    line-height: 1.5;
    color: var(--color-ink);
    max-width: 48ch;
    margin: 0 0 56px;
    font-variation-settings: "opsz" 24;
  }
  .hero-actions {
    display: flex;
    align-items: center;
    gap: 28px;
    margin-bottom: 72px;
    flex-wrap: wrap;
  }
  .captures {
    padding-top: 28px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 15px;
    color: var(--color-ink-muted);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 10px;
  }
  .captures-label {
    font-family: var(--font-body);
    font-style: normal;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--color-ink-faint);
    margin-right: 8px;
  }
  .captures-name { color: var(--color-ink); font-weight: 500; }
  .captures-dot { color: var(--color-accent); }

  /* ─── Chapters ─────────────────────────────────────── */
  .chapter {
    background: var(--color-paper);
  }
  .chapter-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 48px;
    border-top: 1px solid var(--color-rule);
  }
  .chapter-header {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 48px;
    margin-bottom: 80px;
  }
  .chapter-num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    color: var(--color-accent);
    text-transform: uppercase;
    font-variant: small-caps;
    letter-spacing: 0.2em;
    padding-top: 8px;
  }
  .chapter-title {
    font-family: var(--font-display);
    font-size: clamp(40px, 5.5vw, 72px);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.025em;
    max-width: 18ch;
    color: var(--color-ink);
  }
  .chapter-title em {
    font-style: italic;
    font-weight: 400;
  }

  .chapter-body {
    display: grid;
    gap: 48px;
    align-items: start;
    grid-template-columns: 180px minmax(0, 0.9fr) minmax(0, 1.3fr);
  }
  .chapter-body--left {
    grid-template-columns: 180px minmax(0, 1.3fr) minmax(0, 0.9fr);
  }
  .chapter-body--left .chapter-text  { grid-column: 3 / 4; grid-row: 1; }
  .chapter-body--left .chapter-plate { grid-column: 2 / 3; grid-row: 1; }
  .chapter-spacer { display: block; }

  .chapter-lede {
    font-family: var(--font-display);
    font-size: 18px;
    line-height: 1.55;
    color: var(--color-ink);
    max-width: 36ch;
    margin-bottom: 28px;
  }
  .chapter-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-rule);
  }
  .chapter-bullets li {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-ink-muted);
    padding: 14px 0 14px 28px;
    border-bottom: 1px solid var(--color-rule);
    position: relative;
  }
  .chapter-bullets li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }

  .chapter-plate { margin: 0; }
  .chapter-plate-frame {
    border: 1px solid var(--color-rule);
    padding: 6px;
    background: var(--color-paper-soft);
  }
  .chapter-plate-frame img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: top;
  }
  .chapter-plate-caption {
    padding-top: 14px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    color: var(--color-ink-muted);
    text-align: right;
  }

  /* ─── Technical Interlude (dark) ───────────────────── */
  .interlude {
    background: var(--color-dark);
    color: var(--color-dark-text);
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    position: relative;
    overflow: hidden;
  }
  .interlude::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      radial-gradient(ellipse at 20% 0%, rgba(212, 165, 116, 0.06), transparent 60%),
      repeating-linear-gradient(0deg, transparent 0, transparent 28px, rgba(255, 255, 255, 0.018) 28px, rgba(255, 255, 255, 0.018) 29px);
  }
  .interlude-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 140px 48px 160px;
    position: relative;
  }
  .interlude-header {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 48px;
    margin-bottom: 80px;
    align-items: start;
  }
  .interlude-header .eyebrow { padding-top: 10px; }
  .interlude-title {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--color-dark-text);
    max-width: 24ch;
  }
  .interlude-title em {
    font-style: italic;
    color: var(--color-dark-accent);
    font-weight: 400;
  }
  .telemetry {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 48px;
  }
  .telemetry-lede {
    font-family: var(--font-display);
    font-size: 17px;
    font-style: italic;
    line-height: 1.55;
    color: var(--color-dark-muted);
    max-width: 26ch;
    padding-top: 8px;
  }
  .telemetry-panel {
    border: 1px solid var(--color-dark-rule);
    background: var(--color-dark-soft);
    font-family: var(--font-mono);
    position: relative;
  }
  .telemetry-panel::before {
    content: "";
    position: absolute;
    top: -1px;
    left: 48px;
    right: 48px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-dark-accent), transparent);
  }
  .telemetry-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 36px;
    border-bottom: 1px solid var(--color-dark-rule);
  }
  .telemetry-panel-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    color: var(--color-dark-text);
    font-variation-settings: "opsz" 24;
  }
  .telemetry-panel-meta {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-dark-faint);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .telemetry-dot {
    width: 7px;
    height: 7px;
    background: var(--color-dark-accent);
    box-shadow: 0 0 10px var(--color-dark-accent);
    border-radius: 50%;
  }
  .telemetry-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }
  .telemetry-cell {
    padding: 40px 32px 36px;
    border-right: 1px solid var(--color-dark-rule);
  }
  .telemetry-cell:last-child { border-right: none; }
  .telemetry-k {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-dark-faint);
    margin-bottom: 18px;
  }
  .telemetry-v {
    font-family: var(--font-display);
    font-size: 56px;
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--color-dark-text);
    font-variant-numeric: tabular-nums;
    font-variation-settings: "opsz" 144;
  }
  .telemetry-v--accent { color: var(--color-dark-accent); }
  .telemetry-v sup {
    font-size: 0.42em;
    vertical-align: baseline;
    position: relative;
    top: -1.2em;
    color: var(--color-dark-muted);
    font-family: var(--font-mono);
    letter-spacing: 0;
    font-weight: 400;
    margin-left: 2px;
  }
  .telemetry-d {
    margin-top: 16px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    color: var(--color-dark-muted);
    line-height: 1.4;
  }
  .telemetry-panel-footer {
    border-top: 1px solid var(--color-dark-rule);
    padding: 16px 36px;
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-dark-faint);
  }
  .telemetry-cursor {
    color: var(--color-dark-accent);
    animation: blink 1.2s steps(2) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }
  .chapter-plate-caption--dark { color: var(--color-dark-faint); }

  /* ─── Pull quote ───────────────────────────────────── */
  .pullquote { background: var(--color-paper); }
  .pullquote-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 160px 48px;
    text-align: center;
  }
  .pullquote-mark {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 200px;
    line-height: 0.5;
    color: var(--color-accent);
    opacity: 0.7;
    margin-bottom: -28px;
    font-variation-settings: "opsz" 144;
  }
  .pullquote q {
    display: block;
    max-width: 760px;
    margin: 0 auto;
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(28px, 4vw, 44px);
    line-height: 1.25;
    letter-spacing: -0.012em;
    color: var(--color-ink);
    font-variation-settings: "opsz" 72;
    quotes: none;
  }
  .pullquote q::before, .pullquote q::after { content: ""; }
  .pullquote-attrib {
    margin-top: 48px;
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-ink-faint);
  }

  /* ─── FAQ ──────────────────────────────────────────── */
  .faq { background: var(--color-paper); }
  .faq-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 48px;
    border-top: 1px solid var(--color-rule);
  }
  .faq-list {
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-rule);
  }
  .faq-item {
    display: grid;
    grid-template-columns: 180px minmax(0, 1fr) minmax(0, 1.3fr);
    gap: 48px;
    padding: 36px 0;
    border-bottom: 1px solid var(--color-rule);
  }
  .faq-item dt {
    grid-column: 2 / 3;
    font-family: var(--font-display);
    font-weight: 400;
    font-style: italic;
    font-size: 22px;
    line-height: 1.25;
    color: var(--color-ink);
    max-width: 22ch;
    font-variation-settings: "opsz" 36;
  }
