---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout
  title="Blog — Primer"
  description="Updates, guides, and insights about AI coding tool usage and the Primer platform."
>
  <div class="max-w-4xl mx-auto px-6 py-20">
    <header class="mb-16 animate-fade-in-up">
      <h1 class="font-display text-4xl md:text-5xl tracking-tight mb-4">Blog</h1>
      <p class="text-lg text-muted-foreground">
        Updates, guides, and insights from the Primer team.
      </p>
      <p class="text-sm text-muted-foreground/60 mt-2">
        {posts.length} {posts.length === 1 ? "post" : "posts"}
      </p>
      <div class="mt-6 h-px bg-gradient-to-r from-primer-brand via-primer-400 to-transparent"></div>
    </header>

    <div class="space-y-4">
      {posts.map((post, idx) => {
        const formattedDate = new Date(post.data.date).toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        });
        return (
          <article
            class="animate-fade-in-up"
            style={`--delay: ${idx * 80}ms`}
          >
            <a
              href={`${import.meta.env.BASE_URL}blog/${post.id}/`}
              class="group block p-6 rounded-xl border border-border bg-card hover:border-primer-border hover:shadow-md transition-all duration-200"
            >
              <div class="flex items-start justify-between">
                <div class="flex-1 min-w-0">
                  <time class="text-sm text-muted-foreground" datetime={post.data.date}>
                    {formattedDate}
                  </time>
                  <h2 class="font-display text-2xl tracking-tight mt-2 mb-2 group-hover:text-primer-brand transition-colors">
                    {post.data.title}
                  </h2>
                  <p class="text-muted-foreground leading-relaxed">{post.data.description}</p>
                </div>
                <svg class="w-5 h-5 text-muted-foreground/0 group-hover:text-muted-foreground transition-all duration-200 translate-x-0 group-hover:translate-x-0.5 mt-8 ml-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                </svg>
              </div>
            </a>
          </article>
        );
      })}
    </div>
  </div>
</BaseLayout>
