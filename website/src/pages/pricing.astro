---
import BaseLayout from "../layouts/BaseLayout.astro";

const communityFeatures = [
  "Unlimited engineers",
  "Unlimited sessions",
  "Full dashboard & analytics",
  "Cost analysis & trends",
  "Friction detection",
  "MCP sidecar",
  "GitHub PR linking",
  "Alert thresholds",
  "Multi-agent support",
  "REST API access",
  "Audit trail",
  "MIT licensed",
];

const hostedFeatures = [
  "Everything in Community",
  "Managed hosting",
  "Automatic updates",
  "99.9% uptime SLA",
  "SSO / SAML",
  "Priority support",
  "Custom integrations",
];
---

<BaseLayout
  title="Pricing — Primer"
  description="Primer is free and open source. Self-host it on your infrastructure with no limits."
>
  <div class="max-w-5xl mx-auto px-6 py-20">
    <header class="text-center mb-16">
      <h1 class="font-display text-4xl md:text-5xl tracking-tight mb-4">
        Simple, transparent pricing
      </h1>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
        Primer is open source and free to self-host. No usage limits, no per-seat fees.
      </p>
    </header>

    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <!-- Community -->
      <div class="rounded-2xl border-2 border-primer-brand p-8 relative">
        <div class="absolute -top-3 left-6 px-3 py-0.5 bg-primer-brand text-white text-xs font-medium rounded-full">
          Available now
        </div>
        <h2 class="font-display text-2xl mb-2">Community</h2>
        <div class="flex items-baseline gap-1 mb-2">
          <span class="font-display text-5xl tracking-tight">$0</span>
          <span class="text-muted-foreground">/forever</span>
        </div>
        <p class="text-sm text-muted-foreground mb-8">
          Self-hosted on your infrastructure. Full featured, no limits.
        </p>
        <a
          href="/docs/"
          class="block w-full text-center px-6 py-3 rounded-lg bg-primer-brand text-white font-medium hover:bg-primer-600 transition-colors mb-8"
        >
          Get Started
        </a>
        <ul class="space-y-3">
          {communityFeatures.map(feature => (
            <li class="flex items-start gap-3 text-sm">
              <svg class="w-5 h-5 text-emerald-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              {feature}
            </li>
          ))}
        </ul>
      </div>

      <!-- Hosted -->
      <div class="rounded-2xl border border-border p-8 relative opacity-80">
        <div class="absolute -top-3 left-6 px-3 py-0.5 bg-muted text-muted-foreground text-xs font-medium rounded-full">
          Coming soon
        </div>
        <h2 class="font-display text-2xl mb-2">Hosted</h2>
        <div class="flex items-baseline gap-1 mb-2">
          <span class="font-display text-5xl tracking-tight">TBD</span>
        </div>
        <p class="text-sm text-muted-foreground mb-8">
          Managed cloud hosting with enterprise features and SLA.
        </p>
        <button
          disabled
          class="block w-full text-center px-6 py-3 rounded-lg border border-border text-muted-foreground font-medium cursor-not-allowed mb-8"
        >
          Coming Soon
        </button>
        <ul class="space-y-3">
          {hostedFeatures.map(feature => (
            <li class="flex items-start gap-3 text-sm">
              <svg class="w-5 h-5 text-muted-foreground/40 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              {feature}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-16 text-center">
      <p class="text-sm text-muted-foreground">
        Questions about pricing?{" "}
        <a href="https://github.com/ccf/primer/discussions" class="text-primer-brand hover:underline">
          Start a discussion on GitHub
        </a>
      </p>
    </div>
  </div>
</BaseLayout>
