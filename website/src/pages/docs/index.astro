---
import BaseLayout from "../../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;

const tracks = [
  {
    title: "Launch Primer",
    description: "Install the platform, configure auth and storage, and get your first high-signal data in quickly.",
    href: `${base}docs/installation/`,
  },
  {
    title: "Understand the intelligence model",
    description: "See how workflows, customizations, delegation, quality, and cost fit together into one semantic layer.",
    href: `${base}docs/server/`,
  },
  {
    title: "Operationalize the loop",
    description: "Turn insights into interventions, experiments, and repo enablement instead of leaving them in dashboards.",
    href: `${base}docs/insights/`,
  },
];

const sections = [
  {
    title: "Start Here",
    cards: [
      {
        title: "Installation",
        description: "Install Primer, initialize the database, and start the API and dashboard.",
        href: `${base}docs/installation/`,
      },
      {
        title: "Configuration",
        description: "Set up environment variables, auth, storage, and deployment defaults.",
        href: `${base}docs/configuration/`,
      },
      {
        title: "GitHub Integration",
        description: "Connect GitHub OAuth, PR sync, and repository context to Primer's workflow intelligence.",
        href: `${base}docs/github/`,
      },
    ],
  },
  {
    title: "Understand the Platform",
    cards: [
      {
        title: "What Primer Can Tell You",
        description: "A product-level overview of the questions Primer answers across leaders, platform teams, leads, and engineers.",
        href: `${base}docs/insights/`,
      },
      {
        title: "Server & Intelligence Model",
        description: "Architecture, data model, API surfaces, and the derived semantic layer behind workflows, exemplars, and experiments.",
        href: `${base}docs/server/`,
      },
      {
        title: "Hooks & Capture",
        description: "How Primer captures session evidence from multiple agent environments and keeps that telemetry trustworthy.",
        href: `${base}docs/hooks/`,
      },
      {
        title: "MCP Sidecar",
        description: "Bring stats, recommendations, and coaching into the engineer workflow.",
        href: `${base}docs/mcp/`,
      },
    ],
  },
  {
    title: "Operate and Expand",
    cards: [
      {
        title: "Teams & Access",
        description: "Model teams, roles, and access so insights land with the right audience.",
        href: `${base}docs/teams/`,
      },
      {
        title: "FinOps",
        description: "Forecast spend, compare workflows, and reduce cost per successful outcome.",
        href: `${base}docs/finops/`,
      },
      {
        title: "Deployment",
        description: "Run Primer with Docker, production infrastructure, and long-lived shared environments.",
        href: `${base}docs/deployment/`,
      },
      {
        title: "CLI Reference",
        description: "Reference for the `primer` CLI, sync flows, and operational commands.",
        href: `${base}docs/cli/`,
      },
      {
        title: "Alerts",
        description: "Configure thresholds, notifications, and operational signals for rollout management.",
        href: `${base}docs/alerts/`,
      },
    ],
  },
];
---

<BaseLayout
  title="Documentation — Primer Workflow Intelligence"
  description="Documentation for Primer: installation, architecture, workflow intelligence, multi-agent capture, and operational playbooks."
>
  <div class="mx-auto max-w-6xl px-6 py-20">
    <header class="mb-16 animate-fade-in-up">
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-primer-brand">Documentation</p>
      <h1 class="font-display mb-4 text-4xl tracking-tight md:text-5xl">
        Docs for building a workflow intelligence layer
      </h1>
      <p class="max-w-3xl text-lg leading-relaxed text-muted-foreground">
        Primer is no longer just a usage dashboard. These docs explain how to capture trustworthy
        multi-agent telemetry, normalize it into workflows and customizations, and turn the result
        into coaching, experiments, and operating decisions.
      </p>
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {tracks.map((track, idx) => (
          <a
            href={track.href}
            class="rounded-2xl border border-border bg-card p-5 transition-all duration-200 hover:border-primer-border hover:shadow-md animate-fade-in-up"
            style={`--delay: ${idx * 80}ms`}
          >
            <h2 class="mb-2 text-lg font-semibold">{track.title}</h2>
            <p class="text-sm leading-relaxed text-muted-foreground">{track.description}</p>
          </a>
        ))}
      </div>
    </header>

    {sections.map((section, sectionIdx) => (
      <section class="mb-14">
        <div class="mb-6 flex items-center gap-3">
          <h2 class="font-display text-2xl tracking-tight">{section.title}</h2>
          <div class="h-px flex-1 bg-border"></div>
        </div>
        <div class={`grid gap-4 ${section.cards.length >= 4 ? "md:grid-cols-2 xl:grid-cols-3" : "md:grid-cols-3"}`}>
          {section.cards.map((card, cardIdx) => (
            <a
              href={card.href}
              class="group rounded-2xl border border-border bg-card p-5 transition-all duration-200 hover:border-primer-border hover:shadow-md animate-fade-in-up"
              style={`--delay: ${sectionIdx * 100 + cardIdx * 50}ms`}
            >
              <div class="mb-3 flex items-center justify-between">
                <span class="text-xs font-semibold uppercase tracking-[0.22em] text-primer-brand">Guide</span>
                <span class="text-muted-foreground transition-transform duration-200 group-hover:translate-x-1">→</span>
              </div>
              <h3 class="mb-2 text-lg font-semibold group-hover:text-primer-brand transition-colors">{card.title}</h3>
              <p class="text-sm leading-relaxed text-muted-foreground">{card.description}</p>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
