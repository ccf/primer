---
import BaseLayout from "../../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;

const tracks = [
  {
    title: "Launch Primer",
    description: "Install the platform, configure auth and storage, and get your first high-signal data in quickly.",
    href: `${base}docs/installation/`,
  },
  {
    title: "Understand the intelligence model",
    description: "See how workflows, customizations, delegation, quality, and cost fit together into one semantic layer.",
    href: `${base}docs/server/`,
  },
  {
    title: "Operationalize the loop",
    description: "Turn insights into interventions, experiments, and repo enablement instead of leaving them in dashboards.",
    href: `${base}docs/insights/`,
  },
];

const siteOrigin = "https://useprimer.dev";
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Primer Documentation",
    description:
      "Documentation for Primer: installation, architecture, workflow intelligence, multi-agent capture, and operational playbooks.",
    url: `${siteOrigin}/docs/`,
    isPartOf: { "@type": "WebSite", name: "Primer", url: siteOrigin },
    publisher: {
      "@type": "Organization",
      name: "Primer",
      url: siteOrigin,
      logo: { "@type": "ImageObject", url: `${siteOrigin}/logo-mark.svg` },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Documentation",
        item: `${siteOrigin}/docs/`,
      },
    ],
  },
];

const sections = [
  {
    title: "Start Here",
    cards: [
      {
        title: "Installation",
        description: "Install Primer, initialize the database, and start the API and dashboard.",
        href: `${base}docs/installation/`,
      },
      {
        title: "Configuration",
        description: "Set up environment variables, auth, storage, and deployment defaults.",
        href: `${base}docs/configuration/`,
      },
      {
        title: "GitHub Integration",
        description: "Connect GitHub OAuth, PR sync, and repository context to Primer's workflow intelligence.",
        href: `${base}docs/github/`,
      },
    ],
  },
  {
    title: "Understand the Platform",
    cards: [
      {
        title: "What Primer Can Tell You",
        description: "A product-level overview of the questions Primer answers across leaders, platform teams, leads, and engineers.",
        href: `${base}docs/insights/`,
      },
      {
        title: "Server & Intelligence Model",
        description: "Architecture, data model, API surfaces, and the derived semantic layer behind workflows, exemplars, and experiments.",
        href: `${base}docs/server/`,
      },
      {
        title: "Hooks & Capture",
        description: "How Primer captures session evidence from multiple agent environments and keeps that telemetry trustworthy.",
        href: `${base}docs/hooks/`,
      },
      {
        title: "MCP Sidecar",
        description: "Bring stats, recommendations, and coaching into the engineer workflow.",
        href: `${base}docs/mcp/`,
      },
    ],
  },
  {
    title: "Operate and Expand",
    cards: [
      {
        title: "Teams & Access",
        description: "Model teams, roles, and access so insights land with the right audience.",
        href: `${base}docs/teams/`,
      },
      {
        title: "FinOps",
        description: "Forecast spend, compare workflows, and reduce cost per successful outcome.",
        href: `${base}docs/finops/`,
      },
      {
        title: "Deployment",
        description: "Run Primer with Docker, production infrastructure, and long-lived shared environments.",
        href: `${base}docs/deployment/`,
      },
      {
        title: "CLI Reference",
        description: "Reference for the `primer` CLI, sync flows, and operational commands.",
        href: `${base}docs/cli/`,
      },
      {
        title: "Alerts",
        description: "Configure thresholds, notifications, and operational signals for rollout management.",
        href: `${base}docs/alerts/`,
      },
    ],
  },
];
---

<BaseLayout
  title="Documentation — Primer Workflow Intelligence"
  description="Documentation for Primer: installation, architecture, workflow intelligence, multi-agent capture, and operational playbooks."
  structuredData={structuredData}
>
  <div class="docs-index">
    <header class="docs-header reveal">
      <div class="eyebrow"><span>The Field Guide</span></div>
      <h1 class="docs-title font-display">
        Docs for building a<br />workflow intelligence layer
      </h1>
      <p class="docs-lede">
        Primer is no longer just a usage dashboard. These docs explain how to capture trustworthy
        multi-agent telemetry, normalize it into workflows and customizations, and turn the result
        into coaching, experiments, and operating decisions.
      </p>
    </header>

    <div class="tracks reveal" style="--delay: 100ms">
      {tracks.map((track) => (
        <a href={track.href} class="track">
          <h2 class="track-title">{track.title}</h2>
          <p class="track-desc">{track.description}</p>
          <span class="track-arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </div>

    <hr class="hairline section-rule" />

    {sections.map((section) => (
      <section class="doc-section reveal">
        <div class="section-header">
          <h2 class="section-title font-display">{section.title}</h2>
          <hr class="hairline section-line" />
        </div>
        <div class={`card-grid ${section.cards.length >= 4 ? "card-grid--wide" : ""}`}>
          {section.cards.map((card) => (
            <a href={card.href} class="doc-card">
              <h3 class="doc-card-title">{card.title}</h3>
              <p class="doc-card-desc">{card.description}</p>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .docs-index {
    max-width: 960px;
    margin: 0 auto;
    padding: 80px 48px 64px;
  }

  .docs-header {
    margin-bottom: 56px;
  }
  .docs-title {
    font-size: clamp(32px, 5vw, 48px);
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin: 16px 0 24px;
    font-variation-settings: "opsz" 144;
  }
  .docs-lede {
    max-width: 56ch;
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.65;
    color: var(--color-ink-muted);
  }

  /* ─── Tracks (top 3 quick-start links) ──────── */
  .tracks {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-rule);
    border: 1px solid var(--color-rule);
    border-radius: 2px;
    margin-bottom: 56px;
  }
  .track {
    position: relative;
    padding: 28px 24px 36px;
    background: var(--color-paper);
    text-decoration: none;
    transition: background 0.2s;
  }
  .track:hover {
    background: var(--color-paper-soft);
  }
  .track-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 500;
    color: var(--color-ink);
    margin: 0 0 8px;
    letter-spacing: -0.01em;
  }
  .track-desc {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0;
  }
  .track-arrow {
    position: absolute;
    bottom: 12px;
    right: 16px;
    font-size: 14px;
    color: var(--color-ink-faint);
    transition: color 0.2s, transform 0.2s;
  }
  .track:hover .track-arrow {
    color: var(--color-accent);
    transform: translateX(3px);
  }

  .section-rule {
    margin-bottom: 48px;
  }

  /* ─── Sections ──────────────────────────────── */
  .doc-section {
    margin-bottom: 48px;
  }
  .section-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 20px;
  }
  .section-title {
    font-size: 22px;
    font-weight: 400;
    color: var(--color-ink);
    white-space: nowrap;
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 144;
  }
  .section-line {
    flex: 1;
  }

  /* ─── Card grid ─────────────────────────────── */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    border-radius: 2px;
  }

  .doc-card {
    padding: 24px;
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    margin-top: -1px;
    margin-left: -1px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .doc-card:hover {
    background: var(--color-paper-soft);
  }
  .doc-card-title {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 6px;
    transition: color 0.2s;
  }
  .doc-card:hover .doc-card-title {
    color: var(--color-accent);
  }
  .doc-card-desc {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-ink-muted);
    margin: 0;
  }

  @media (max-width: 720px) {
    .docs-index {
      padding: 56px 24px 40px;
    }
    .tracks {
      grid-template-columns: 1fr;
    }
    .card-grid,
    .card-grid--wide {
      grid-template-columns: 1fr;
    }
  }
</style>
