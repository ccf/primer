      },
      {
        title: "Alert Thresholds",
        description: "Set up cost and usage alerts for your team.",
        href: `${base}docs/alerts/`,
        icon: "M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0",
      },
      {
        title: "Deployment",
        description: "Deploy Primer with Docker Compose or Kubernetes.",
        href: `${base}docs/deployment/`,
        icon: "M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z",
      },
    ],
  },
];
---

<BaseLayout
  title="Documentation — Primer"
  description="Learn how to install, configure, and use Primer to track AI coding tool usage across your team."
>
  <div class="max-w-6xl mx-auto px-6 py-20">
    <header class="mb-16 animate-fade-in-up">
      <h1 class="font-display text-4xl md:text-5xl tracking-tight mb-4">Documentation</h1>
      <p class="text-lg text-muted-foreground max-w-2xl">
        Learn what Primer can tell you about your organization's AI usage, then set it up and start getting insights.
      </p>
      <p class="text-sm text-muted-foreground/60 mt-2">
        13 guides across Getting Started, Architecture, and Guides
      </p>
      <!-- Gradient accent line -->
      <div class="mt-6 h-px bg-gradient-to-r from-primer-brand via-primer-400 to-transparent"></div>
    </header>

    {sections.map((section, sectionIdx) => (
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <h2 class="font-display text-2xl tracking-tight">{section.title}</h2>
          <div class="flex-1 h-px bg-border"></div>
        </div>
        <div class="grid md:grid-cols-3 gap-4">
          {section.cards.map((card, cardIdx) => (
            <a
              href={card.href}
              class="group relative p-5 rounded-xl border border-border bg-card hover:border-primer-border hover:shadow-md transition-all duration-200 hover:border-l-primer-brand animate-fade-in-up"
              style={`--delay: ${sectionIdx * 100 + cardIdx * 60}ms`}
            >
              <div class="flex items-start justify-between">
                <div class="w-9 h-9 rounded-lg bg-primer-surface flex items-center justify-center mb-3">
                  <svg class="w-4.5 h-4.5 text-primer-brand" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d={card.icon} />
                  </svg>
                </div>
                <svg class="w-4 h-4 text-muted-foreground/0 group-hover:text-muted-foreground transition-all duration-200 translate-x-0 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                </svg>
              </div>
              <h3 class="font-semibold mb-1 group-hover:text-primer-brand transition-colors">{card.title}</h3>
              <p class="text-sm text-muted-foreground">{card.description}</p>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</BaseLayout>
