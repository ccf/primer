---
import BaseLayout from "../layouts/BaseLayout.astro";

const rows = [
  {
    feature: "Workflow fingerprints tied to cost and quality",
    primer: "Core product surface",
    analytics: "Rare or partial",
    diy: "High lift",
  },
  {
    feature: "Exemplar sessions and bright spots",
    primer: "Built in",
    analytics: "Usually absent",
    diy: "Manual curation",
  },
  {
    feature: "Prompt, skill, template, and command reuse analytics",
    primer: "Built in",
    analytics: "Usually absent",
    diy: "Fragmented scripts",
  },
  {
    feature: "Customization intelligence for MCPs, skills, commands, and subagents",
    primer: "Built in",
    analytics: "Rare",
    diy: "Custom collectors",
  },
  {
    feature: "Delegation graphs and agent-team mode analysis",
    primer: "Built in",
    analytics: "Rare",
    diy: "Very high lift",
  },
  {
    feature: "Recommendation -> intervention -> experiment loop",
    primer: "Built in",
    analytics: "Usually absent",
    diy: "Operational overhead",
  },
  {
    feature: "Self-hosted and privacy-first",
    primer: "Yes",
    analytics: "Varies",
    diy: "Yes",
  },
  {
    feature: "Open source and extensible",
    primer: "Yes",
    analytics: "Usually no",
    diy: "Depends on your stack",
  },
  {
    feature: "Cross-agent support with source-aware trust model",
    primer: "Yes",
    analytics: "Often uneven",
    diy: "Manual normalization",
  },
];

const differentiators = [
  {
    title: "Primer vs generic analytics dashboards",
    description:
      "Most usage dashboards stop at activity, adoption, and spend. Primer is built to connect workflows, reusable assets, customizations, delegation, quality, and cost into one operating model.",
  },
  {
    title: "Primer vs DIY pipelines",
    description:
      "You can always stitch together event collectors, SQL, notebooks, and internal dashboards. Primer shortens the distance from raw evidence to coaching, experiments, and standardized playbooks.",
  },
  {
    title: "Primer's position",
    description:
      "The product is strongest when it answers: which workflows should we copy, which customizations matter, and which changes actually improved outcomes.",
  },
];
---

<BaseLayout
  title="Compare — Primer vs Usage Dashboards and DIY"
  description="Compare Primer to generic AI analytics dashboards and DIY stacks. Primer is built for workflow intelligence, exemplars, experiments, and agent stack analysis."
>
  <div class="mx-auto max-w-6xl px-6 py-20">
    <header class="mb-14 text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-primer-brand">Compare</p>
      <h1 class="font-display mb-4 text-4xl tracking-tight md:text-5xl">
        Primer is built for workflow intelligence, not just usage reporting
      </h1>
      <p class="mx-auto max-w-3xl text-lg leading-relaxed text-muted-foreground">
        The real differentiator is not that Primer captures AI usage. It is that Primer helps you
        decide which workflows, assets, customizations, and rollout changes are worth standardizing.
      </p>
    </header>

    <div class="mb-14 grid gap-6 md:grid-cols-3">
      {differentiators.map((item, idx) => (
        <div
          class="rounded-2xl border border-border bg-card p-6 shadow-sm animate-fade-in-up"
          style={`--delay: ${idx * 80}ms`}
        >
          <h2 class="mb-3 text-xl font-semibold">{item.title}</h2>
          <p class="text-sm leading-relaxed text-muted-foreground">{item.description}</p>
        </div>
      ))}
    </div>

    <div class="overflow-x-auto rounded-2xl border border-border bg-card shadow-sm">
      <table class="w-full min-w-[760px] text-sm">
        <thead>
          <tr class="border-b border-border bg-muted/40">
            <th class="px-5 py-4 text-left font-semibold">Capability</th>
            <th class="px-5 py-4 text-center font-semibold text-primer-brand">Primer</th>
            <th class="px-5 py-4 text-center font-semibold">Typical analytics tool</th>
            <th class="px-5 py-4 text-center font-semibold">DIY stack</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row, idx) => (
            <tr class={idx % 2 === 0 ? "border-b border-border/60" : "border-b border-border/60 bg-muted/20"}>
              <td class="px-5 py-4 align-top">{row.feature}</td>
              <td class="px-5 py-4 text-center align-top font-medium text-primer-brand">{row.primer}</td>
              <td class="px-5 py-4 text-center align-top text-muted-foreground">{row.analytics}</td>
              <td class="px-5 py-4 text-center align-top text-muted-foreground">{row.diy}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="mt-14 rounded-2xl bg-hero-bg px-8 py-10 text-center text-hero-text">
      <h2 class="font-display mb-3 text-3xl tracking-tight">What Primer helps you decide</h2>
      <p class="mx-auto mb-8 max-w-3xl text-lg leading-relaxed text-white/66">
        Which workflows deserve standardization. Which prompts and assets are worth copying. Which
        customizations differentiate high performers. Which changes actually improved outcomes.
      </p>
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={`${import.meta.env.BASE_URL}docs/`}
          class="inline-flex items-center rounded-lg bg-primer-brand px-6 py-3 font-medium text-white transition-colors hover:bg-primer-600"
        >
          Read the docs
        </a>
        <a
          href="https://github.com/ccf/primer"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center rounded-lg border border-white/15 bg-white/8 px-6 py-3 font-medium text-white transition-colors hover:bg-white/12"
        >
          Explore the repo
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
