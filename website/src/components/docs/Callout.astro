---
interface Props {
  type?: "note" | "tip" | "warning" | "important";
  title?: string;
}

const { type = "note", title } = Astro.props;

const styles = {
  note: {
    border: "border-blue-500/50",
    bg: "bg-blue-500/10",
    icon: "ℹ",
    iconColor: "text-blue-400",
    titleColor: "text-blue-300",
  },
  tip: {
    border: "border-emerald-500/50",
    bg: "bg-emerald-500/10",
    icon: "✦",
    iconColor: "text-emerald-400",
    titleColor: "text-emerald-300",
  },
  warning: {
    border: "border-amber-500/50",
    bg: "bg-amber-500/10",
    icon: "⚠",
    iconColor: "text-amber-400",
    titleColor: "text-amber-300",
  },
  important: {
    border: "border-red-500/50",
    bg: "bg-red-500/10",
    icon: "!",
    iconColor: "text-red-400",
    titleColor: "text-red-300",
  },
};

const s = styles[type];
---

<div class:list={["not-prose my-6 rounded-lg border-l-4 px-4 py-3", s.border, s.bg]}>
  <div class="flex items-start gap-3">
    <span class:list={["mt-0.5 text-base font-bold leading-none select-none", s.iconColor]} aria-hidden="true">
      {s.icon}
    </span>
    <div class="min-w-0 flex-1 text-sm leading-relaxed text-foreground/90">
      {title && (
        <p class:list={["mb-1 font-semibold", s.titleColor]}>{title}</p>
      )}
      <slot />
    </div>
  </div>
</div>
