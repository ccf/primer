---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
const columns = [
  {
    title: "Product",
    links: [
      { href: `${base}#features`, label: "Features" },
      { href: `${base}docs/`, label: "Documentation" },
      { href: `${base}blog/`, label: "Blog" },
    ],
  },
  {
    title: "Community",
    links: [
      { href: "https://github.com/ccf/primer", label: "GitHub" },
      { href: "https://github.com/ccf/primer/issues", label: "Issues" },
      { href: "https://github.com/ccf/primer/discussions", label: "Discussions" },
      { href: "https://github.com/ccf/primer/blob/main/LICENSE", label: "MIT License" },
    ],
  },
];
---

<footer class="border-t border-border bg-muted/50">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <!-- Brand column -->
      <div class="col-span-2 md:col-span-2">
        <a href={base} class="flex items-center gap-2 mb-4">
          <img src={`${base}logo-mark.svg`} alt="" width="24" height="24" class="dark:hidden" />
          <img src={`${base}logo-mark-light.svg`} alt="" width="24" height="24" class="hidden dark:block" />
          <span class="font-display text-lg tracking-tight">primer</span>
        </a>
        <p class="text-sm text-muted-foreground leading-relaxed">
          See how your team uses AI coding tools. Open source, self-hosted, privacy-first.
        </p>
      </div>

      {columns.map(col => (
        <div>
          <h3 class="text-sm font-semibold mb-3">{col.title}</h3>
          <ul class="space-y-2">
            {col.links.map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-muted-foreground hover:text-foreground transition-colors"
                  {...(link.href.startsWith("http") ? { target: "_blank", rel: "noopener" } : {})}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-8 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-muted-foreground">
        &copy; {year} Primer. Released under the MIT License.
      </p>
      <p class="text-xs text-muted-foreground/60">
        Named after the Young Lady's Illustrated Primer
      </p>
    </div>
  </div>
</footer>
