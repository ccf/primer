---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();

const columns = [
  {
    title: "The Book",
    links: [
      { href: `${base}#faq`, label: "Common questions" },
      { href: `${base}docs/`, label: "Field guide" },
      { href: `${base}docs/installation/`, label: "Install" },
      { href: `${base}docs/server/`, label: "Architecture" },
    ],
  },
  {
    title: "Community",
    links: [
      { href: "https://github.com/ccf/primer", label: "GitHub" },
      { href: "https://github.com/ccf/primer/issues", label: "Issues" },
      { href: "https://github.com/ccf/primer/discussions", label: "Discussions" },
      { href: "https://github.com/ccf/primer/blob/main/LICENSE", label: "MIT License" },
    ],
  },
];
---

<footer class="ed-footer">
  <div class="ed-footer__inner">
    <div class="ed-footer__top">
      <div class="ed-footer__brand">
        <a href={base} class="ed-footer__mark" aria-label="Primer">Primer</a>
        <p class="ed-footer__tag">
          <em>See which AI workflows actually work.</em>
        </p>
      </div>

      {columns.map((col) => (
        <div class="ed-footer__col">
          <h3 class="ed-footer__col-title">{col.title}</h3>
          <ul>
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  {...(link.href.startsWith("http") ? { target: "_blank", rel: "noopener" } : {})}
                >{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <hr class="ed-footer__rule" />

    <div class="ed-footer__bottom">
      <p>&copy; {year} Charles C. Figueiredo · Released under the MIT License.</p>
      <p class="ed-footer__epigraph">Named after the Young Lady's Illustrated Primer.</p>
    </div>
  </div>
</footer>

<style>
  .ed-footer {
    background: var(--color-paper);
    border-top: 1px solid var(--color-rule);
  }
  .ed-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 80px 48px 56px;
  }
  .ed-footer__top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 56px;
  }
  .ed-footer__brand {
    max-width: 38ch;
  }
  .ed-footer__mark {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 28px;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    text-decoration: none;
    font-variation-settings: "opsz" 144;
  }
  .ed-footer__tag {
    margin-top: 16px;
    font-family: var(--font-display);
    font-size: 16px;
    line-height: 1.5;
    color: var(--color-ink-muted);
  }
  .ed-footer__col-title {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--color-ink-faint);
    margin: 0 0 18px;
  }
  .ed-footer__col ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .ed-footer__col li {
    margin-bottom: 10px;
  }
  .ed-footer__col a {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .ed-footer__col a:hover { color: var(--color-accent); }

  .ed-footer__rule {
    border: 0;
    border-top: 1px solid var(--color-rule);
    margin: 0 0 28px;
  }
  .ed-footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 12px;
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-ink-muted);
  }
  .ed-footer__epigraph {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-ink-faint);
  }

  @media (max-width: 720px) {
    .ed-footer__inner { padding: 64px 28px 40px; }
    .ed-footer__top {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
