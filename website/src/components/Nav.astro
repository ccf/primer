---
const base = import.meta.env.BASE_URL;
const links = [
  { href: `${base}#faq`, label: "FAQ" },
  { href: `${base}docs/`, label: "Docs" },
  { href: "https://github.com/ccf/primer", label: "GitHub", external: true },
];
---

<nav class="ed-nav">
  <div class="ed-nav__inner">
    <a href={base} class="ed-nav__brand" aria-label="Primer home">Primer</a>

    <div class="ed-nav__links">
      {links.map((link) => (
        <a
          href={link.href}
          target={link.external ? "_blank" : undefined}
          rel={link.external ? "noopener" : undefined}
        >{link.label}</a>
      ))}
    </div>

    <a href="https://demo.useprimer.dev" class="ed-nav__cta">Live demo →</a>

    <button id="mobile-menu-btn" class="ed-nav__mobile" aria-label="Menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M3 6h18M3 12h18M3 18h18" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="ed-nav__mobile-menu">
    {links.map((link) => (
      <a
        href={link.href}
        target={link.external ? "_blank" : undefined}
        rel={link.external ? "noopener" : undefined}
      >{link.label}</a>
    ))}
    <a href="https://demo.useprimer.dev" class="ed-nav__mobile-cta">Live demo →</a>
  </div>
</nav>

<style>
  .ed-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-paper) 92%, transparent);
    backdrop-filter: saturate(180%) blur(10px);
    -webkit-backdrop-filter: saturate(180%) blur(10px);
    border-bottom: 1px solid var(--color-rule);
  }
  .ed-nav__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 18px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .ed-nav__brand {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    text-decoration: none;
    font-variation-settings: "opsz" 144;
  }
  .ed-nav__links {
    display: flex;
    gap: 32px;
  }
  .ed-nav__links a {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .ed-nav__links a:hover { color: var(--color-ink); }

  .ed-nav__cta {
    background: var(--color-ink);
    color: var(--color-paper);
    padding: 10px 18px;
    border-radius: 2px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s;
  }
  .ed-nav__cta:hover { background: var(--color-accent); }

  .ed-nav__mobile {
    display: none;
    background: transparent;
    border: none;
    color: var(--color-ink);
    cursor: pointer;
  }

  .ed-nav__mobile-menu {
    display: none;
    flex-direction: column;
    gap: 16px;
    padding: 24px 28px;
    border-top: 1px solid var(--color-rule);
    background: var(--color-paper);
  }
  .ed-nav__mobile-menu.open { display: flex; }
  .ed-nav__mobile-menu a {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-ink);
    text-decoration: none;
  }
  .ed-nav__mobile-cta {
    margin-top: 8px;
    background: var(--color-ink);
    color: var(--color-paper);
    padding: 12px 18px;
    border-radius: 2px;
    text-align: center;
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  @media (max-width: 720px) {
    .ed-nav__inner { padding: 14px 28px; }
    .ed-nav__links,
    .ed-nav__cta { display: none; }
    .ed-nav__mobile { display: block; }
  }
</style>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => menu?.classList.toggle("open"));
</script>
