---
const base = import.meta.env.BASE_URL;
const links = [
  { href: `${base}#faq`, label: "FAQ" },
  { href: `${base}docs/`, label: "Docs" },
];
const githubHref = "https://github.com/ccf/primer";
---

<nav class="ed-nav">
  <div class="ed-nav__inner">
    <a href={base} class="ed-nav__brand" aria-label="Primer home">Primer</a>

    <div class="ed-nav__links">
      {links.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
      <a
        href={githubHref}
        target="_blank"
        rel="noopener"
        class="ed-nav__icon-link"
        aria-label="Primer on GitHub"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.73.5.75 5.48.75 11.75c0 4.97 3.22 9.18 7.69 10.67.56.1.77-.24.77-.54 0-.27-.01-1.16-.02-2.1-3.13.68-3.79-1.34-3.79-1.34-.51-1.3-1.25-1.64-1.25-1.64-1.02-.7.08-.68.08-.68 1.13.08 1.72 1.16 1.72 1.16 1 1.72 2.63 1.22 3.27.93.1-.73.39-1.22.71-1.5-2.5-.28-5.13-1.25-5.13-5.57 0-1.23.44-2.24 1.16-3.03-.12-.28-.5-1.43.11-2.98 0 0 .94-.3 3.08 1.16a10.7 10.7 0 0 1 5.61 0c2.14-1.46 3.08-1.16 3.08-1.16.61 1.55.23 2.7.11 2.98.72.79 1.16 1.8 1.16 3.03 0 4.33-2.64 5.28-5.15 5.56.4.35.76 1.03.76 2.08 0 1.5-.01 2.71-.01 3.08 0 .3.21.65.78.54 4.46-1.49 7.68-5.7 7.68-10.67C23.25 5.48 18.27.5 12 .5z"/>
        </svg>
      </a>
    </div>

    <a href="https://demo.useprimer.dev" class="ed-nav__cta">Live demo →</a>

    <button id="mobile-menu-btn" class="ed-nav__mobile" aria-label="Menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M3 6h18M3 12h18M3 18h18" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="ed-nav__mobile-menu">
    {links.map((link) => (
      <a href={link.href}>{link.label}</a>
    ))}
    <a href={githubHref} target="_blank" rel="noopener">GitHub</a>
    <a href="https://demo.useprimer.dev" class="ed-nav__mobile-cta">Live demo →</a>
  </div>
</nav>

<style>
  .ed-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-paper) 92%, transparent);
    backdrop-filter: saturate(180%) blur(10px);
    -webkit-backdrop-filter: saturate(180%) blur(10px);
    border-bottom: 1px solid var(--color-rule);
  }
  .ed-nav__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 18px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .ed-nav__brand {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    text-decoration: none;
    font-variation-settings: "opsz" 144;
  }
  .ed-nav__links {
    display: flex;
    gap: 32px;
  }
  .ed-nav__links a {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .ed-nav__links a:hover { color: var(--color-ink); }

  .ed-nav__icon-link {
    display: inline-flex;
    align-items: center;
    color: var(--color-ink-muted);
    transition: color 0.2s;
  }
  .ed-nav__icon-link:hover { color: var(--color-ink); }

  .ed-nav__cta {
    background: var(--color-ink);
    color: var(--color-paper);
    padding: 10px 18px;
    border-radius: 2px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s;
  }
  .ed-nav__cta:hover { background: var(--color-accent); }

  .ed-nav__mobile {
    display: none;
    background: transparent;
    border: none;
    color: var(--color-ink);
    cursor: pointer;
  }

  .ed-nav__mobile-menu {
    display: none;
    flex-direction: column;
    gap: 16px;
    padding: 24px 28px;
    border-top: 1px solid var(--color-rule);
    background: var(--color-paper);
  }
  .ed-nav__mobile-menu.open { display: flex; }
  .ed-nav__mobile-menu a {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-ink);
    text-decoration: none;
  }
  .ed-nav__mobile-cta {
    margin-top: 8px;
    background: var(--color-ink);
    color: var(--color-paper);
    padding: 12px 18px;
    border-radius: 2px;
    text-align: center;
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  @media (max-width: 720px) {
    .ed-nav__inner { padding: 14px 28px; }
    .ed-nav__links,
    .ed-nav__cta { display: none; }
    .ed-nav__mobile { display: block; }
  }
</style>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => menu?.classList.toggle("open"));
</script>
